{
  "name": "@ootmm/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "./deploy.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "preact": "catalog:",
    "preact-iso": "^2.11.1",
    "react-icons": "catalog:",
    "reset-css": "^5.0.2",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@ootmm/web-components": "*",
    "@preact/preset-vite": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "vite-multiple-assets": "^2.2.6"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "{projectRoot}/**/*",
          {
            "env": "STATIC_URL"
          }
        ],
        "outputs": [
          "{projectRoot}/dist/**/*"
        ],
        "dependsOn": []
      },
      "dev": {
        "inputs": [
          "{projectRoot}/**/*",
          {
            "env": "STATIC_URL"
          }
        ],
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
